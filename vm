def print_box(title: str, content: str):
    """Print content in a beautiful box"""
    print(Colors.CYAN + "┌" + "─" * (len(title) + 2) + "┐" + Colors.END)
    print(Colors.CYAN + "│" + Colors.BOLD + title + Colors.END + Colors.CYAN + "│" + Colors.END)
    print(Colors.CYAN + "├" + "─" * (len(title) + 2) + "┤" + Colors.END)
    for line in content.split('\n'):
        print(Colors.CYAN + "│" + Colors.END + " " + line + " " * (len(title) - len(line)) + Colors.CYAN + "│" + Colors.END)
    print(Colors.CYAN + "└" + "─" * (len(title) + 2) + "┘" + Colors.END)

def progress_bar(current: int, total: int, prefix: str = '', suffix: str = '', length: int = 40):
    """Display a progress bar"""
    percent = 100 * (current / float(total))
    filled_length = int(length * current // total)
    bar = '█' * filled_length + '░' * (length - filled_length)
    
    # Color based on percentage
    if percent < 30:
        bar_color = Colors.RED
    elif percent < 70:
        bar_color = Colors.YELLOW
    else:
        bar_color = Colors.GREEN
    
    print(f'\r{prefix} |{bar_color}{bar}{Colors.END}| {percent:.0f}% {suffix}', end='')
    if current == total:
        print()

# ==================== AUTO INSTALLER ====================
def check_and_install_adb() -> bool:
    """Auto-detect and install ADB if missing"""
    print_status("Checking ADB installation...", "check")
    
    try:
        subprocess.run(['adb', 'version'], capture_output=True, check=True)
        print_status("ADB is already installed", "success")
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        print_status("ADB not found. Installing automatically...", "warning")
        
        # Detect package manager
        try:
            # Try pkg (Termux)
            subprocess.run(['pkg', 'update'], capture_output=True, timeout=30)
            subprocess.run(['pkg', 'install', 'android-tools', '-y'], capture_output=True, timeout=60)
            print_status("ADB installed successfully via pkg", "success")
            return True
        except:
            try:
                # Try apt (Linux)
                subprocess.run(['sudo', 'apt', 'update'], capture_output=True, timeout=30)
                subprocess.run(['sudo', 'apt', 'install', 'android-tools-adb', '-y'], capture_output=True, timeout=60)
                print_status("ADB installed successfully via apt", "success")
                return True
            except:
                try:
                    # Try pacman (Arch)
                    subprocess.run(['sudo', 'pacman', '-S', 'android-tools', '--noconfirm'], capture_output=True, timeout=60)
                    print_status("ADB installed successfully via pacman", "success")
                    return True
                except:
                    print_status("Failed to install ADB automatically", "error")
                    print_status("Please install manually: pkg install android-tools", "warning")
                    return False

# ==================== ADB FUNCTIONS ====================
def run_adb(command: List[str], device_id: Optional[str] = None) -> Tuple[bool, str]:
    """Execute ADB command with error handling"""
    try:
        if device_id:
            cmd = ['adb', '-s', device_id] + command
        else:
            cmd = ['adb'] + command
        
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        
        if result.returncode == 0:
            return True, result.stdout.strip()
        else:
            return False, result.stderr.strip()
    except subprocess.TimeoutExpired:
        return False, "Command timeout"
    except Exception as e:
        return False, str(e)

def get_connected_device() -> Optional[str]:
    """Get first connected device"""
    success, output = run_adb(['devices'])
    if not success:
        return None
    
    for line in output.split('\n'):
        if line.strip() and 'device' in line and 'offline' not in line:
            return line.split('\t')[0]
    return None

def get_device_status(device_id: str) -> dict:
    """Get comprehensive device status"""
    status = {
        'connected': False,
        'model': 'Unknown',
        'android': 'Unknown',
        'resolution': 'Unknown',
        'density': 'Unknown',
        'battery': 'Unknown',
        'available_ram': 'Unknown'
    }
    
    # Check connection
    success, _ = run_adb(['shell', 'echo', 'test'], device_id)
    if not success:
        return status
    
    status['connected'] = True
    
    # Get model
    success, output = run_adb(['shell', 'getprop', 'ro.product.model'], device_id)
    if success:
        status['model'] = output
    
    # Get Android version
    success, output = run_adb(['shell', 'getprop', 'ro.build.version.release'], device_id)
    if success:
        status['android'] = output
    
    # Get resolution
    success, output = run_adb(['shell', 'wm', 'size'], device_id)
    if success and 'Physical size:' in output:
        status['resolution'] = output.split('Physical size:')[1].strip()
    
    # Get density
    success, output = run_adb(['shell', 'wm', 'density'], device_id)
    if success and 'Physical density:' in output:
        status['density'] = output.split('Physical density:')[1].strip()
    
    # Get battery
    success, output = run_adb(['shell', 'dumpsys', 'battery', '|', 'grep', 'level'], device_id)
    if success and 'level:' in output:
        status['battery'] = output.split('level:')[1].strip() + '%'
    
    # Get RAM info
    success, output = run_adb(['shell', 'free', '-m'], device_id)
    if success:
        lines = output.split('\n')
        for line in lines:
            if 'Mem:' in line:
                parts = line.split()
                if len(parts) >= 3:
                    total = int(parts[1])
                    available = int(parts[2])
                    used = total - available
                    status['available_ram'] = f"{available}MB / {total}MB ({int((available/total)*100)}% free)"
    
    return status

def backup_current_settings(device_id: str) -> bool:
    """Backup current resolution and density"""
    print_status("Backing up current settings...", "progress")
    
    # Backup resolution
    success, output = run_adb(['shell', 'wm', 'size'], device_id)
    if success:
        run_adb(['shell', f"echo '{output}' > /sdcard/resolution_backup.txt"], device_id)
    
    # Backup density
    success, output = run_adb(['shell', 'wm', 'density'], device_id)
    if success:
        run_adb(['shell', f"echo '{output}' > /sdcard/density_backup.txt"], device_id)
    
    print_status("Settings backed up to /sdcard/", "success")
    return True

def apply_optimization(device_id: str, callback=None) -> bool:
    """Apply all optimizations with progress tracking"""
    steps = [
        ("Changing resolution to 550x1550", "wm size 550x1550"),
        ("Adjusting DPI for better display", "wm density 240"),
        ("Killing Facebook", "am force-stop com.facebook.katana"),
        ("Killing Instagram", "am force-stop com.instagram.android"),
        ("Killing WhatsApp", "am force-stop com.whatsapp"),
        ("Killing TikTok", "am force-stop com.zhiliaoapp.musically"),
        ("Killing Snapchat", "am force-stop com.snapchat.android"),
        ("Killing Twitter", "am force-stop com.twitter.android"),
        ("Killing YouTube", "am force-stop com.google.android.youtube"),
        ("Clearing cache", "pm trim-caches 9999999999"),
        ("Optimizing memory", "echo 3 > /proc/sys/vm/drop_caches")
    ]
    
    total_steps = len(steps)
    for i, (description, command) in enumerate(steps):
        if callback:
            callback(i + 1, total_steps, description)
        
        # Execute command
        if command.startswith("wm") or command.startswith("am") or command.startswith("pm"):
            run_adb(['shell', command], device_id)
        elif command.startswith("echo"):
            run_adb(['shell', command], device_id)
    
    return True

def restore_default(device_id: str, callback=None) -> bool:
    """Restore all default settings"""
    steps = [
        ("Restoring original resolution", "wm size reset"),
        ("Restoring original DPI", "wm density reset"),
        ("Cleaning up", "echo 'Restored to default'")
    ]
    
    total_steps = len(steps)
    for i, (description, command) in enumerate(steps):
        if callback:
            callback(i + 1, total_steps, description)
        
        if command.startswith("wm") or command.startswith("echo"):
            run_adb(['shell', command], device_id)
    
    return True

